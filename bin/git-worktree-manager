#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage: git-worktree-manager <command> [options]

Opinionated worktree manager for bare-clone repos.
Expects the layout created by git-clone-bare-worktree:

  project/
    .bare/        bare clone
    .git          gitdir pointer
    main/         worktree (default branch)

Commands:
  run [--name NAME] [--ref REF] [--] <command...>
      Create a worktree and run a command inside it.
      Worktree persists after the command exits.
      --name NAME   Worktree directory name (default: wt-<random>)
      --ref REF     Git ref to base the worktree on (default: HEAD)

  ls  List all worktrees.

  rm <name>
      Remove a worktree and delete its wt/<name> branch.

Examples:
  git-worktree-manager run --name fix-bug -- claude-isolated "fix the login bug"
  git-worktree-manager run -- bash
  git-worktree-manager ls
  git-worktree-manager rm fix-bug
EOF
  exit 1
}

find_project_root() {
  local dir="$PWD"
  while [[ "$dir" != "/" ]]; do
    if [[ -d "$dir/.bare" ]]; then
      echo "$dir"
      return
    fi
    dir="$(dirname "$dir")"
  done
  echo "error: not inside a bare-worktree project (no .bare/ found)" >&2
  exit 1
}

generate_name() {
  echo "wt-$(od -An -tx1 -N4 /dev/urandom | tr -d ' \n')"
}

cmd_run() {
  local name="" ref="HEAD"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --name) name="$2"; shift 2 ;;
      --ref)  ref="$2"; shift 2 ;;
      --)     shift; break ;;
      -*)     echo "error: unknown option '$1'" >&2; exit 1 ;;
      *)      break ;;
    esac
  done

  if [[ $# -eq 0 ]]; then
    echo "error: no command specified" >&2
    exit 1
  fi

  local root
  root="$(find_project_root)"

  if [[ -z "$name" ]]; then
    name="$(generate_name)"
  fi

  local branch="wt/$name"
  local worktree_path="$root/$name"

  if [[ -d "$worktree_path" ]]; then
    echo "error: worktree '$name' already exists at $worktree_path" >&2
    exit 1
  fi

  # Ensure relative gitdir paths so worktrees survive container remounting.
  # Run `git worktree repair` in existing repos to backfill this for older worktrees.
  git -C "$root/.bare" config core.repositoryFormatVersion 1
  git -C "$root/.bare" config extensions.relativeWorktrees true

  git -C "$root" worktree add "$worktree_path" -b "$branch" "$ref"
  echo "Created worktree '$name' at $worktree_path (branch: $branch)"

  cd "$worktree_path"
  exec "$@"
}

cmd_ls() {
  local root
  root="$(find_project_root)"
  git -C "$root" worktree list
}

cmd_rm() {
  if [[ $# -lt 1 ]]; then
    echo "error: name required" >&2
    exit 1
  fi

  local name="$1"
  local root
  root="$(find_project_root)"
  local branch="wt/$name"
  local worktree_path="$root/$name"

  if [[ ! -d "$worktree_path" ]]; then
    echo "error: worktree '$name' not found at $worktree_path" >&2
    exit 1
  fi

  git -C "$root" worktree remove "$worktree_path"
  git -C "$root" branch -D "$branch" 2>/dev/null && echo "Deleted branch $branch" || true
  echo "Removed worktree '$name'"
}

[[ $# -lt 1 ]] && usage

command="$1"
shift

case "$command" in
  run) cmd_run "$@" ;;
  ls)  cmd_ls ;;
  rm)  cmd_rm "$@" ;;
  *)   usage ;;
esac
