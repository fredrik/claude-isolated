#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.10"
# ///
"""Run Claude Code in isolated Podman containers."""

import argparse
import os
import random
import subprocess
import sys
from pathlib import Path

PROJECT_ROOT = Path(__file__).resolve().parent.parent
WORDLIST = PROJECT_ROOT / "config" / "wordlist.txt"
IMAGE = "claude-isolated:latest"


def generate_name() -> str:
    adjectives: list[str] = []
    nouns: list[str] = []
    section = "adj"
    for line in WORDLIST.read_text().splitlines():
        if line.startswith("#"):
            continue
        if not line.strip():
            section = "noun"
            continue
        if section == "adj":
            adjectives.append(line.strip())
        else:
            nouns.append(line.strip())
    adj = random.choice(adjectives)
    noun = random.choice(nouns)
    return f"claude-isolated-{adj}-{noun}"


def init_home() -> Path:
    return Path(os.environ.get("CLAUDE_ISOLATED_HOME", Path.home() / ".config" / "claude-isolated" / "home"))


def cmd_build(args: argparse.Namespace) -> None:
    subprocess.run(["podman", "build", "-t", IMAGE, str(PROJECT_ROOT)], check=True)
    print(f"Image built: {IMAGE}")


def cmd_start(args: argparse.Namespace) -> None:
    workspace = Path(".").resolve()

    name = generate_name()
    isolated_home = init_home()

    required = [
        isolated_home / ".claude.json",
        isolated_home / ".claude" / "settings.json",
        isolated_home / ".ssh",
        isolated_home / ".gitconfig",
        isolated_home / ".config" / "gh" / "hosts.yml",
    ]
    for f in required:
        if not f.exists():
            print(f"Missing: {f}", file=sys.stderr)
            print(f"Bootstrap with:", file=sys.stderr)
            print(f"  cp -r {PROJECT_ROOT / 'home.example'} {isolated_home}", file=sys.stderr)
            print("Then edit the files with your actual config.", file=sys.stderr)
            sys.exit(1)

    run_args = [
        "podman", "run", "-it", "--rm",
        "--name", name,
        "-e", f"CLAUDE_ISOLATED_NAME={name}",
        "-v", f"{workspace}:/workspace:rw",
        "-v", f"{isolated_home / '.claude.json'}:/home/claude/.claude.json:rw",
        "-v", f"{isolated_home / '.claude' / 'settings.json'}:/home/claude/.claude/settings.json:rw",
        "-v", f"{isolated_home / '.claude' / 'CLAUDE.md'}:/home/claude/.claude/CLAUDE.md:ro",
        "-v", f"{isolated_home / '.ssh'}:/home/claude/.ssh:ro",
        "-v", f"{isolated_home / '.gitconfig'}:/home/claude/.gitconfig:ro",
        "-v", f"{isolated_home / '.config' / 'gh'}:/home/claude/.config/gh:rw",
    ]

    creds = isolated_home / ".claude" / ".credentials.json"
    if creds.exists():
        run_args += ["-v", f"{creds}:/home/claude/.claude/.credentials.json:rw"]

    run_args += [IMAGE, "claude", "--dangerously-skip-permissions"]
    if args.prompt:
        run_args.append(args.prompt)

    os.execvp("podman", run_args)


def cmd_enter(args: argparse.Namespace) -> None:
    os.execvp("podman", [
        "podman", "exec", "-it", args.name,
        "zellij", "attach", "--create", args.name,
    ])


def cmd_stop(args: argparse.Namespace) -> None:
    subprocess.run(["podman", "stop", "-t", "2", args.name], capture_output=True)
    subprocess.run(["podman", "rm", args.name], capture_output=True)
    print(f"Stopped and removed: {args.name}")


def cmd_ls(args: argparse.Namespace) -> None:
    subprocess.run([
        "podman", "ps",
        "--filter", f"ancestor={IMAGE}",
        "--format", "table {{.Names}}\t{{.Status}}\t{{.Created}}",
    ], check=True)


SUBCOMMANDS = {"build", "start", "enter", "stop", "ls"}


def main() -> None:
    # If first arg isn't a subcommand, treat as default: build + start [prompt]
    if not sys.argv[1:] or sys.argv[1] not in SUBCOMMANDS:
        prompt = sys.argv[1] if len(sys.argv) > 1 else ""
        subprocess.run(["podman", "build", "-t", IMAGE, str(PROJECT_ROOT)],
                       check=True, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        args = argparse.Namespace(prompt=prompt)
        cmd_start(args)
        return

    parser = argparse.ArgumentParser(description="Run Claude Code in isolated Podman containers")
    sub = parser.add_subparsers(dest="command")

    sub.add_parser("build", help="Build the container image")

    p_start = sub.add_parser("start", help="Start a new container")
    p_start.add_argument("prompt", nargs="?", default="", help="Optional prompt for Claude")

    p_enter = sub.add_parser("enter", help="Attach to a running container's Zellij session")
    p_enter.add_argument("name", help="Container name")

    p_stop = sub.add_parser("stop", help="Stop and remove a container")
    p_stop.add_argument("name", help="Container name")

    sub.add_parser("ls", help="List running containers")

    args = parser.parse_args()

    commands = {
        "build": cmd_build,
        "start": cmd_start,
        "enter": cmd_enter,
        "stop": cmd_stop,
        "ls": cmd_ls,
    }
    commands[args.command](args)


if __name__ == "__main__":
    main()
