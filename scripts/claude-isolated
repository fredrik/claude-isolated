#!/usr/bin/env bash
set -euo pipefail

SOURCE="$0"
while [[ -L "$SOURCE" ]]; do
    SCRIPT_DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
    SOURCE="$(readlink "$SOURCE")"
    [[ "$SOURCE" != /* ]] && SOURCE="$SCRIPT_DIR/$SOURCE"
done
SCRIPT_DIR="$(cd "$(dirname "$SOURCE")" && pwd)"

# Default: build + start <project-dir>
if [[ $# -eq 0 ]] || [[ ! -x "$SCRIPT_DIR/claude-isolated-$1" ]]; then
    "$SCRIPT_DIR/claude-isolated-build"
    exec "$SCRIPT_DIR/claude-isolated-start" "${@:-.}"
fi

cmd="$1"
shift

subcmd="$SCRIPT_DIR/claude-isolated-${cmd}"
if [[ ! -x "$subcmd" ]]; then
    echo "Unknown command: $cmd" >&2
    echo "Available commands:" >&2
    for f in "$SCRIPT_DIR"/claude-isolated-*; do
        [[ -x "$f" ]] && echo "  ${f##*claude-isolated-}" >&2
    done
    exit 1
fi

exec "$subcmd" "$@"
