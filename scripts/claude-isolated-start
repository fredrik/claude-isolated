#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"
WORDLIST="$PROJECT_ROOT/config/wordlist.txt"

# --- Args ---
PROJECT_DIR="${1:?Usage: claude-isolated-start <project-dir>}"
PROJECT_DIR="$(cd "$PROJECT_DIR" && pwd)"  # resolve to absolute

# --- Generate name ---
ADJECTIVES=()
NOUNS=()
section="adj"
while IFS= read -r line; do
    [[ "$line" =~ ^# ]] && continue
    [[ -z "$line" ]] && { section="noun"; continue; }
    if [[ "$section" == "adj" ]]; then
        ADJECTIVES+=("$line")
    else
        NOUNS+=("$line")
    fi
done < "$WORDLIST"

ADJ="${ADJECTIVES[$((RANDOM % ${#ADJECTIVES[@]}))]}"
NOUN="${NOUNS[$((RANDOM % ${#NOUNS[@]}))]}"
NAME="claude-isolated-${ADJ}-${NOUN}"

# --- Host paths ---
INIT_HOME="${CLAUDE_ISOLATED_HOME:-$HOME/.config/claude-isolated/home}"

# --- Validate required files ---
for f in "$INIT_HOME/.claude.json" "$INIT_HOME/.claude/settings.json" "$INIT_HOME/.ssh" "$INIT_HOME/.gitconfig"; do
    if [[ ! -e "$f" ]]; then
        echo "Missing: $f" >&2
        echo "Bootstrap with:" >&2
        echo "  cp -r $PROJECT_ROOT/home.example $INIT_HOME" >&2
        echo "Then edit the files with your actual config." >&2
        exit 1
    fi
done

# --- Optional mounts ---
OPTIONAL_MOUNTS=()
if [[ -e "$INIT_HOME/.claude/credentials.json" ]]; then
    OPTIONAL_MOUNTS+=(-v "$INIT_HOME/.claude/credentials.json:/home/claude/.claude/.credentials.json:rw")
fi

# --- Start container ---
podman run -it --rm \
    --name "$NAME" \
    -e "CLAUDE_ISOLATED_NAME=$NAME" \
    -v "$PROJECT_DIR:/workspace:rw" \
    -v "$INIT_HOME/.claude.json:/home/claude/.claude.json:rw" \
    -v "$INIT_HOME/.claude/settings.json:/home/claude/.claude/settings.json:rw" \
    -v "$INIT_HOME/.claude/CLAUDE.md:/home/claude/.claude/CLAUDE.md:ro" \
    -v "$INIT_HOME/.ssh:/home/claude/.ssh:ro" \
    -v "$INIT_HOME/.gitconfig:/home/claude/.gitconfig:ro" \
    "${OPTIONAL_MOUNTS[@]}" \
    claude-isolated:latest \
    zellij --session "$NAME"
